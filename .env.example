# --- Database ---
DB_URL=postgres://appboard:appboard@localhost:5441/appboard

# --- HTTP server ---
PORT=6680
# Comma-separated list of CORS-allowed origins (e.g. your admin panel URL)
ALLOWED_ORIGINS=http://localhost:6600

# --- Crypto ---
# 32-byte hex key used for AES-256-GCM encryption of store credentials.
# Generate one with: openssl rand -hex 32
# NEVER reuse the example value in production.
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Better Auth ---
# Minimum 32 characters. Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=your-secret-here-min-32-chars-long!!
BETTER_AUTH_URL=http://localhost:6680

NODE_ENV=development

# --- Bootstrap admin (self-hosting without SMTP) ---
# When both are set and the user doesn't exist yet, an owner account is created
# on startup so you can log in with email + password (no email OTP / SMTP needed).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Social login (optional) ---
# A provider only activates when BOTH its id and secret are set; otherwise the
# backend runs with just email/OTP. The same keys can be reused across services
# — add each backend's callback URL to the shared OAuth client.
#
# Google: create an OAuth Client (Web application) in Google Cloud Console and
# add redirect URI: http://localhost:6680/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Apple: Services ID + a Sign in with Apple key. APPLE_CLIENT_SECRET is a signed
# ES256 JWT (max 6 months). Apple requires a public HTTPS redirect — no
# localhost; use a tunnel or test on staging. Callback:
# https://<host>/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
# Optional: native iOS app bundle id (only for verifying native id tokens).
APPLE_APP_BUNDLE_ID=

# --- Local bootstrap seed (optional) ---
# `bun run db:seed` creates an owner user + workspace from these values.
# Leave SEED_USER_EMAIL empty to skip seeding (default). Ships no personal data.
SEED_USER_EMAIL=
SEED_USER_NAME=

# --- Test auth bypass (dev/test only) ---
# Enables the X-Test-User-Id header so local e2e scripts can authenticate.
# The test suite (`bun test`) enables it automatically via NODE_ENV=test.
# NEVER honored when NODE_ENV=production.
ENABLE_TEST_AUTH=

# --- AI (OpenRouter) ---
# Required only if you enable the AI feature flag.
OPENROUTER_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemini-3-flash-preview

# SMTP (e.g. Postmark). Leave empty in DEVELOPMENT to use the fixed dev OTP
# (123456) — no email needed for local login. In PRODUCTION the server refuses
# to start without SMTP configured, so there is no fixed-OTP login in prod.
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your-postmark-server-api-token
SMTP_PASS=your-postmark-server-api-token
SMTP_FROM=noreply@yourdomain.com

# --- Background scheduler (rank tracking + auto-research) ---
# In-process timer that runs daily rank checks (00:00 & 12:00 local) and
# auto-research. Set to "false" to disable (e.g. a second instance that must not
# double-run jobs). Automatically disabled under the test runner.
SCHEDULER_ENABLED=true
# IANA timezone the daily rank-check slots are anchored to.
SCHEDULER_TZ=Europe/Warsaw

# --- Product feedback form ---
# Recipient for the public feedback widget on the marketing site. Left empty =
# feedback endpoint returns "temporarily unavailable".
FEEDBACK_EMAIL=

# --- Listmonk newsletter (optional) ---
# Feedback submitters are added as subscribers. All four must be set to activate.
# Auth uses a Listmonk API user token: `Authorization: token <user>:<token>`.
LISTMONK_URL=
LISTMONK_USERNAME=
LISTMONK_TOKEN=
LISTMONK_LIST_ID=

# Real ASC integration tests (run with: ASC_INTEGRATION=1 bun test src/test/real-asc-integration.test.ts)
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY=
ASC_TEST_APP_ID=

# Real Google Play integration tests (run with: GP_INTEGRATION=1 bun test src/test/real-gp-integration.test.ts)
GP_SERVICE_ACCOUNT_JSON=
GP_TEST_PACKAGE_NAME=
# Path to a local Google Play service-account key file (used by scripts/test-gp-*.ts).
# Keep the key file under ./keys (gitignored) — never commit credentials.
GP_SERVICE_ACCOUNT_KEY_PATH=
