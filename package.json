{
	"name": "appboard-backend",
	"version": "0.5.5",
	"description": "Open-source ASO (App Store Optimization) management backend \u2014 connect App Store Connect & Google Play, sync metadata, manage listings, screenshots, reviews, and publish via one API.",
	"license": "MIT",
	"author": "Eryk Kruk",
	"homepage": "https://github.com/erykkruk/appboard-backend#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/erykkruk/appboard-backend.git"
	},
	"bugs": {
		"url": "https://github.com/erykkruk/appboard-backend/issues"
	},
	"keywords": [
		"aso",
		"app-store",
		"app-store-optimization",
		"app-store-connect",
		"google-play",
		"self-hosted",
		"bun",
		"elysia",
		"typescript",
		"drizzle"
	],
	"engines": {
		"bun": ">=1.3"
	},
	"bin": {
		"appboard": "src/cli/index.ts"
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "bun run --watch src/index.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"db:up": "docker-compose up -d postgres",
		"db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
		"db:seed": "bun run scripts/seed.ts",
		"db:seed:demo": "bun run scripts/seed-demo.ts",
		"mcp:server": "bun run src/mcp/index.ts",
		"cli": "bun run src/cli/index.ts",
		"prepare": "husky",
		"demo:reset": "bun run scripts/reset-demo.ts"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/eden": "^1.4.8",
		"@elysiajs/openapi": "^1.4.14",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@sinclair/typebox": "^0.34.48",
		"arktype": "^2.1.29",
		"better-auth": "^1.4.19",
		"drizzle-orm": "^0.45.1",
		"drizzle-typebox": "^0.3.3",
		"elysia": "1.4.22",
		"google-play-scraper": "^10.1.3",
		"googleapis": "^171.4.0",
		"jose": "^6.1.3",
		"node-app-store-connect-api": "^5.0.6",
		"nodemailer": "^8.0.1",
		"pino": "^10.3.0",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/nodemailer": "^7.0.11",
		"@types/sharp": "^0.32.0",
		"app-store-scraper": "^0.18.0",
		"bun-types": "1.3.7",
		"drizzle-kit": "^0.31.8",
		"husky": "^9.1.7",
		"pino-pretty": "^13.1.3",
		"typescript": "^5.9.3"
	},
	"module": "src/index.js"
}
