{
	"name": "appboard-be",
	"version": "0.1.0",
	"scripts": {
		"start": "bun run src/index.ts",
		"dev": "pkill -f 'bun run --watch src/index.ts' 2>/dev/null; sleep 0.5; bun run --watch src/index.ts",
		"test": "bun test",
		"db:up": "docker-compose up -d postgres",
		"db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"@sinclair/typebox": "^0.34.48",
		"arktype": "^2.1.29",
		"drizzle-orm": "^0.45.1",
		"drizzle-typebox": "^0.3.3",
		"elysia": "1.4.22",
		"pino": "^10.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"bun-types": "1.3.7",
		"drizzle-kit": "^0.31.8",
		"husky": "^9.1.7",
		"pino-pretty": "^13.1.3",
		"typescript": "^5.9.3"
	},
	"module": "src/index.js"
}
