# Copy to .env for the self-hosted stack: docker compose -f compose.selfhost.yaml up -d

# Public URL where the panel is reached (set to your https reverse-proxy URL).
APP_URL=http://localhost:6600
WEB_PORT=6600

# Deployment edition. Leave "selfhosted" (default) for self-hosting — this hides
# cloud-only features (e.g. billing). Only our hosted cloud sets it to "cloud".
DEPLOYMENT_MODE=selfhosted

# Database
POSTGRES_USER=appboard
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=appboard

# Auth — min 32 chars. Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Leave blank to auto-generate + persist a 64-hex AES key on first boot,
# or set your own: openssl rand -hex 32
ENCRYPTION_KEY=

# Log in with email + password, no SMTP needed (created on first boot).
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=

# Optional: configure SMTP for email OTP login instead of the admin account.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: enable AI features with your own OpenRouter key.
OPENROUTER_API_KEY=
